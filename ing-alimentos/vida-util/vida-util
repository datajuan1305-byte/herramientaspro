  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}

function fmt(n, dec=2) {
  return Number(n).toLocaleString('es-CO', { minimumFractionDigits: dec, maximumFractionDigits: dec });
}

const R = 8.314; // J/(mol·K) — constante de gases

function autoEa() {
  const prod = document.getElementById('a-producto').value;
  const ea = { lacteo:80, carne:100, grasa:70, panificado:60, fruta:50, bebida:90, enlatado:110, custom:80 };
  document.getElementById('a-ea').value = ea[prod] || 80;
}

// ── ARRHENIUS ──
function calcularArrhenius() {
  const tempRef  = parseFloat(document.getElementById('a-temp-ref').value) + 273.15;
  const vidaRef  = parseFloat(document.getElementById('a-vida-ref').value);
  const unidad   = document.getElementById('a-unidad').value;
  const ea       = parseFloat(document.getElementById('a-ea').value) * 1000; // J/mol
  const tempObj  = parseFloat(document.getElementById('a-temp-obj').value) + 273.15;

  // k_ref / k_obj = exp(Ea/R * (1/T_ref - 1/T_obj))
  // vida_obj = vida_ref * (k_ref / k_obj) = vida_ref * exp(Ea/R * (1/T_obj - 1/T_ref))
  const factor = Math.exp((ea / R) * (1/tempObj - 1/tempRef));
  const vidaObj = vidaRef * factor;

  const unidades = { dias:'días', semanas:'semanas', meses:'meses' };
  const label = unidades[unidad];

  // Factor de aceleración (cuántas veces más rápido deteriora a T_obj vs T_ref)
  const factorAceleracion = factor < 1 ? 1/factor : factor;
  const esMasLarga = factor > 1;

  // Proyección a múltiples temperaturas
  const temps = [-18, 0, 4, 10, 15, 20, 25, 30, 35, 40];
  const proyeccion = temps.map(t => {
    const tk = t + 273.15;
    const f = Math.exp((ea / R) * (1/tk - 1/tempRef));
    return { temp: t, vida: vidaRef * f };
  });

  const tempObjC = parseFloat(document.getElementById('a-temp-obj').value);

  document.getElementById('resultado-arrhenius').style.display = 'block';
  document.getElementById('resultado-arrhenius').innerHTML = `
    <div class="resultado-box">
      <div class="resultado-titulo">Resultado — Modelo de Arrhenius</div>
      <div class="resultado-vida">${fmt(vidaObj, 1)} ${label}</div>
      <div class="resultado-sub">Vida útil estimada a ${tempObjC}°C</div>
      <div class="resultado-grid">
        <div class="resultado-item"><div class="resultado-valor">${fmt(vidaObj, 1)}</div><div class="resultado-label">Vida útil a ${tempObjC}°C (${label})</div></div>
        <div class="resultado-item"><div class="resultado-valor">${fmt(factor, 2)}×</div><div class="resultado-label">Factor relativo vs referencia</div></div>
        <div class="resultado-item"><div class="resultado-valor">${ea/1000} kJ/mol</div><div class="resultado-label">Energía activación (Ea)</div></div>
        <div class="resultado-item"><div class="resultado-valor">${vidaRef} ${label}</div><div class="resultado-label">Vida útil referencia (${parseFloat(document.getElementById('a-temp-ref').value)}°C)</div></div>
      </div>
      <div class="resultado-detalle">
        <b>Ecuación de Arrhenius aplicada:</b><br>
        k(T) = A × exp(−Ea/RT)<br>
        Factor = exp(Ea/R × (1/T₂ − 1/T₁))<br>
        Factor = exp(${ea/1000}×1000/8.314 × (1/${fmt(tempObj,2)} − 1/${fmt(tempRef,2)})) = <b>${fmt(factor,4)}</b><br>
        Vida útil a ${tempObjC}°C = ${vidaRef} × ${fmt(factor,4)} = <b>${fmt(vidaObj,2)} ${label}</b><br>
        ${esMasLarga ? `✅ A menor temperatura el producto dura <b>${fmt(factor,1)}× más</b> que a la temperatura de referencia.`
          : `⚠️ A mayor temperatura el producto dura <b>${fmt(1/factor,1)}× menos</b> que a la temperatura de referencia.`}
      </div>
      <div style="overflow-x:auto; margin-top:1rem;">
        <table class="tabla-proyeccion">
          <thead><tr><th>Temperatura</th><th>Vida útil estimada (${label})</th><th>Factor vs ${parseFloat(document.getElementById('a-temp-ref').value)}°C</th></tr></thead>
          <tbody>
            ${proyeccion.map(p => {
              const f = Math.exp((ea/R)*(1/(p.temp+273.15)-1/tempRef));
              const esRef = Math.abs(p.temp - (parseFloat(document.getElementById('a-temp-ref').value))) < 0.5;
              const esObj = Math.abs(p.temp - tempObjC) < 0.5;
              return `<tr class="${esRef||esObj?'referencia':''}">
                <td>${p.temp}°C${esRef?' ← Referencia':''}${esObj?' ← Objetivo':''}</td>
                <td>${fmt(p.vida,1)}</td>
                <td>${fmt(f,2)}×</td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      </div>
    </div>`;
}

// ── Q10 ──
function calcularQ10() {
  const vidaRef  = parseFloat(document.getElementById('q-vida-ref').value);
  const tempRef  = parseFloat(document.getElementById('q-temp-ref').value);
  const q10      = parseFloat(document.getElementById('q-q10').value);
  const tempObj  = parseFloat(document.getElementById('q-temp-obj').value);

  const deltaT  = tempObj - tempRef;
  const factor  = Math.pow(q10, deltaT / 10);
  // vida_obj = vida_ref / factor (si T_obj > T_ref, vida es menor)
  const vidaObj = vidaRef / factor;

  const temps = [0, 4, 10, 15, 20, 25, 30, 35, 40];
  const proyeccion = temps.map(t => ({
    temp: t,
    vida: vidaRef / Math.pow(q10, (t - tempRef) / 10)
  }));

  document.getElementById('resultado-q10').style.display = 'block';
  document.getElementById('resultado-q10').innerHTML = `
    <div class="resultado-box">
      <div class="resultado-titulo">Resultado — Factor Q10</div>
      <div class="resultado-vida">${fmt(vidaObj, 1)} días</div>
      <div class="resultado-sub">Vida útil estimada a ${tempObj}°C con Q10 = ${q10}</div>
      <div class="resultado-grid">
        <div class="resultado-item"><div class="resultado-valor">${fmt(vidaObj,1)} días</div><div class="resultado-label">Vida útil a ${tempObj}°C</div></div>
        <div class="resultado-item"><div class="resultado-valor">${q10}</div><div class="resultado-label">Factor Q10</div></div>
        <div class="resultado-item"><div class="resultado-valor">${fmt(factor,2)}×</div><div class="resultado-label">Factor aceleración</div></div>
        <div class="resultado-item"><div class="resultado-valor">${deltaT > 0 ? '+' : ''}${deltaT}°C</div><div class="resultado-label">Diferencia de temperatura</div></div>
      </div>
      <div class="resultado-detalle">
        <b>Fórmula Q10:</b> Vida útil(T₂) = Vida útil(T₁) ÷ Q10^((T₂−T₁)/10)<br>
        ΔT = ${tempObj}°C − ${tempRef}°C = ${deltaT}°C<br>
        Factor = Q10^(ΔT/10) = ${q10}^(${deltaT}/10) = <b>${fmt(factor,4)}</b><br>
        Vida útil a ${tempObj}°C = ${vidaRef} ÷ ${fmt(factor,4)} = <b>${fmt(vidaObj,2)} días</b>
      </div>
      <div style="overflow-x:auto; margin-top:1rem;">
        <table class="tabla-proyeccion">
          <thead><tr><th>Temperatura</th><th>Vida útil (días)</th><th>Vida útil (meses)</th></tr></thead>
          <tbody>
            ${proyeccion.map(p => {
              const esRef = Math.abs(p.temp - tempRef) < 0.5;
              const esObj = Math.abs(p.temp - tempObj) < 0.5;
              return `<tr class="${esRef||esObj?'referencia':''}">
                <td>${p.temp}°C${esRef?' ← Ref':''}${esObj?' ← Objetivo':''}</td>
                <td>${fmt(Math.max(0,p.vida),1)}</td>
                <td>${fmt(Math.max(0,p.vida/30),1)}</td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      </div>
    </div>`;
}

// ── ASLT ──
function calcularASLT() {
  const tNormal    = parseFloat(document.getElementById('ac-temp-normal').value);
  const tAcelerada = parseFloat(document.getElementById('ac-temp-acelerada').value);
  const vidaEsperada = parseFloat(document.getElementById('ac-vida-esperada').value);
  const q10        = parseFloat(document.getElementById('ac-q10').value);
  const ea         = parseFloat(document.getElementById('ac-ea').value) * 1000;
  const parametro  = document.getElementById('ac-parametro').value;

  const deltaT = tAcelerada - tNormal;
  const factorQ10 = Math.pow(q10, deltaT / 10);
  const factorArr = Math.exp((ea/R)*((1/(tNormal+273.15))-(1/(tAcelerada+273.15))));

  // Duración del estudio acelerado
  const duracionQ10 = (vidaEsperada * 30) / factorQ10; // en días
  const duracionArr = (vidaEsperada * 30) / factorArr;

  // Puntos de muestreo sugeridos (7 puntos distribuidos)
  const nPuntos = 7;
  const intervaloDias = Math.round(duracionQ10 / (nPuntos - 1));
  const puntosQ10 = Array.from({length: nPuntos}, (_, i) => Math.round(i * intervaloDias));

  const paramLabels = {
    sensorial: 'Análisis sensorial (panel entrenado)',
    microbiologico: 'Recuento microbiano (UFC/g)',
    fisicoquimico: 'pH, acidez, Aw, humedad',
    oxidacion: 'TBARS, índice de peróxido, anisidina',
    vitaminas: 'HPLC vitaminas (C, B1, B2, etc.)'
  };

  document.getElementById('resultado-aslt').style.display = 'block';
  document.getElementById('resultado-aslt').innerHTML = `
    <div class="resultado-box">
      <div class="resultado-titulo">Diseño Estudio ASLT — Vida útil declarada: ${vidaEsperada} meses a ${tNormal}°C</div>
      <div class="resultado-vida">${fmt(duracionQ10, 0)} días</div>
      <div class="resultado-sub">Duración del estudio acelerado a ${tAcelerada}°C (modelo Q10)</div>
      <div class="resultado-grid">
        <div class="resultado-item"><div class="resultado-valor">${fmt(duracionQ10,0)} días</div><div class="resultado-label">Duración estudio (Q10)</div></div>
        <div class="resultado-item"><div class="resultado-valor">${fmt(duracionArr,0)} días</div><div class="resultado-label">Duración estudio (Arrhenius)</div></div>
        <div class="resultado-item"><div class="resultado-valor">${fmt(factorQ10,1)}×</div><div class="resultado-label">Factor aceleración</div></div>
        <div class="resultado-item"><div class="resultado-valor">${nPuntos} puntos</div><div class="resultado-label">Muestreos sugeridos</div></div>
      </div>
      <div class="resultado-detalle">
        <b>Condiciones del estudio:</b><br>
        Temperatura normal: ${tNormal}°C | Temperatura acelerada: ${tAcelerada}°C | ΔT: +${deltaT}°C<br>
        Factor aceleración Q10: ${q10}^(${deltaT}/10) = <b>${fmt(factorQ10,2)}×</b><br>
        Factor aceleración Arrhenius (Ea=${ea/1000} kJ/mol): <b>${fmt(factorArr,2)}×</b><br>
        Vida útil esperada: ${vidaEsperada} meses (${vidaEsperada*30} días a ${tNormal}°C)<br>
        <b>Duración del estudio acelerado: ${fmt(duracionQ10,0)} días (~${fmt(duracionQ10/30,1)} meses) a ${tAcelerada}°C</b><br><br>
        <b>Parámetro a monitorear:</b> ${paramLabels[parametro]}<br><br>
        <b>Cronograma de muestreo sugerido (días):</b><br>
        ${puntosQ10.map((d,i) => `Punto ${i+1}: día ${d}`).join(' | ')}
      </div>
    </div>
    <div style="background:rgba(255,255,255,0.12); border-radius:8px; padding:1rem; margin-top:0.8rem; color:#fff; font-size:0.83rem;">
      <b style="color:#ffe082;">📋 Documentos requeridos por INVIMA:</b><br>
      • Protocolo del estudio con fundamento científico<br>
      • Resultados de análisis en puntos de muestreo definidos<br>
      • Concepto de un profesional competente (Ing. de Alimentos o similar)<br>
      • Validación con estudio en tiempo real en condiciones normales (paralelo)
    </div>`;
}
</script>
